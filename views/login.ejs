<!DOCTYPE html>

<html>
<head>
    <title>UniEvent Secure - Login</title>

 
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

    body {
        background: #f5f7fa;
        overflow: hidden;
    }

  .right-side {
    position: fixed;
    top: 0;
    right: 0;
    width: 65%;
    height: 100vh;

    background-image: url('/bau-campus.png');
    background-size: cover;
    background-position: center;

    clip-path: ellipse(70% 100% at 100% 50%);

    overflow: hidden;
}

.right-side::before {
    content: "";
    position: absolute;
    inset: 0;

    background: rgba(11, 31, 77, 0.65);
}

    .login-card {
           width: 500px;
    border-radius: 20px;

    }

    .logo {
        height: 110px;
    }
    .login-wrapper {
    width: 50%;
    height: 100vh;

    display: flex;
    justify-content: center;
    align-items: center;

    position: relative;
    z-index: 10;
}
.btn-login {
    height: 50px;

    display: flex;
    align-items: center;
    justify-content: center;

    font-weight: 600;
}

</style>
 

</head>

<body>

<div class="right-side"></div>

<div class="login-wrapper">
 
<div class="card shadow-lg login-card">

    <div class="card-body p-5">

        <div class="text-center">

           <img
    src="/logo.png"
    alt="Logo"
    class="logo mb-4"
>

            <h2 class="fw-bold text-primary mb-3">
                UniEvent Secure
            </h2>

            <p class="text-muted mb-4">
                Secure University Event Management System
            </p>

        </div>

        <form action="/login" method="POST">

            <div class="mb-3">

                <label class="form-label">
                    Email
                </label>

                <input
                    type="email"
                    name="email"
                    class="form-control"
                    placeholder="Enter your email"
                    required
                >

            </div>

            <div class="mb-3">

                <label class="form-label">
                    Password
                </label>

                <input
                    type="password"
                    name="password"
                    class="form-control"
                    placeholder="Enter your password"
                    required
                >

            </div>

            <button
                type="submit"
                class="btn btn-primary w-100 btn-login">
                Login
            </button>

            <div class="d-flex justify-content-between mt-3">

                <a href="/register">
                    Create Account
                </a>

                

            </div>

        </form>

    </div>

</div>
 

</div>

</body>
</html>
