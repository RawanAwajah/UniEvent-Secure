<!DOCTYPE html>

<html>
<head>
    <title>UniEvent Secure - Register</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

    body {
        background: #f5f7fa;
        overflow: hidden;
    }

    .right-side {
        position: fixed;
        top: 0;
        right: 0;
        width: 50%;
        height: 100vh;

        background-image: url('/bau-campus.png');
        background-size: cover;
        background-position: center;

        clip-path: ellipse(70% 100% at 100% 50%);
        overflow: hidden;
    }

    .right-side::before {
        content: "";
        position: absolute;
        inset: 0;
        background: rgba(11, 31, 77, 0.65);
    }

    .register-wrapper {
        width: 50%;
        height: 100vh;

        display: flex;
        justify-content: center;
        align-items: center;

        position: relative;
        z-index: 10;
    }

    .register-card {
        width: 500px;
        border-radius: 20px;
    }

    .logo {
        height: 90px;
        width: auto;
    }

    .btn-register {
        height: 50px;

        display: flex;
        align-items: center;
        justify-content: center;

        font-weight: 600;
    }

</style>


</head>

<body>

<div class="right-side"></div>

<div class="register-wrapper">


<div class="card shadow-lg register-card">

    <div class="card-body p-5">

        <div class="text-center mb-4">

            <img
                src="/logo.png"
                class="logo mb-4"
                alt="Logo"
            >

            <h2 class="fw-bold text-primary mb-3">
                UniEvent Secure
            </h2>

            <p class="text-muted mb-4">
                Secure University Event Management System
            </p>

        </div>

       <h4 class="text-center fw-semibold text-primary mb-4">
    Create Your Account
</h4>

        <form action="/register" method="POST">

            <div class="mb-3">
                <label class="form-label">
                    Full Name
                </label>

                <input
                    type="text"
                    name="name"
                    class="form-control"
                    placeholder="Enter your full name"
                    required
                >
            </div>

            <div class="mb-3">
                <label class="form-label">
                    Email Address
                </label>

                <input
                    type="email"
                    name="email"
                    class="form-control"
                    placeholder="Enter your email"
                    required
                >
            </div>

            <div class="mb-4">
                <label class="form-label">
                    Password
                </label>

                <input
                    type="password"
                    name="password"
                    class="form-control"
                    placeholder="Create a password"
                    required
                >
            </div>

            <button
                type="submit"
                class="btn btn-primary w-100 btn-register">
                Create Account
            </button>

        </form>

        <div class="text-center mt-4">

            <p class="mb-0">
                Already have an account?
                <a href="/login">
                    Login
                </a>
            </p>

        </div>

    </div>

</div>

</div>

</body>
</html>
