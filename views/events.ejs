<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Available Events | UniEvent Secure</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8fafc;
            min-height: 100vh;
            color: #1e293b;
        }

        .navbar-custom {
            background-color: #0a2d6d;
            padding: 15px 0;
        }

        .page-title {
            font-weight: 700;
            color: #0a2d6d;
            letter-spacing: -0.02em;
        }

        .event-main-card {
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 20px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .event-main-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 25px rgba(10, 45, 109, 0.08);
            border-color: #cbd5e1;
        }

        .card-title-text {
            font-weight: 700;
            font-size: 1.25rem;
            color: #0a2d6d;
            letter-spacing: -0.01em;
        }

        .meta-container p {
            font-size: 0.9rem;
            margin-bottom: 8px;
            color: #475569;
        }

        .meta-label {
            font-weight: 600;
            color: #1e293b;
        }

        .category-badge {
            background-color: rgba(10, 45, 109, 0.06);
            color: #0a2d6d;
            font-weight: 600;
            font-size: 0.75rem;
            padding: 6px 12px;
            border-radius: 30px;
            display: inline-block;
            text-transform: capitalize;
        }

        .btn-primary {
            background-color: #0a2d6d;
            color: #ffffff;
            border: none;
            font-weight: 600;
            border-radius: 10px;
            padding: 10px 20px;
            transition: all 0.2s ease;
        }

        .btn-primary:hover {
            background-color: #061c47;
            color: #ffffff;
            transform: scale(1.01);
        }
    </style>
</head>

<body>

<nav class="navbar navbar-expand-lg navbar-dark navbar-custom shadow-sm">
    <div class="container">
        <a class="navbar-brand fw-bold text-white" href="/dashboard">
            UniEvent<span class="text-info">Secure</span>
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarContent">
            <div class="navbar-nav ms-auto gap-2">
                <a class="nav-link text-white-50" href="/dashboard">Dashboard</a>
                <a class="nav-link active text-white" href="/events">Events</a>
                <a class="nav-link text-white-50" href="/my-bookings">My Bookings</a>
                <a class="nav-link text-white-50" href="/profile">Profile</a>
                <a class="nav-link text-warning fw-semibold" href="/logout">Logout</a>
            </div>
        </div>
    </div>
</nav>

<div class="container mt-5">

    <% if(locals.message && message) { %>
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm rounded-4 p-3 mb-4 d-flex align-items-center justify-content-between" style="background-color: #ecfdf5; color: #065f46;">
            <div class="d-flex align-items-center gap-2">
                <span>✨</span>
                <p class="mb-0 small fw-semibold"><%= message %></p>
            </div>
            <button type="button" class="btn-close shadow-none" data-bs-dismiss="alert" aria-label="Close" style="font-size: 0.75rem;"></button>
        </div>
    <% } %>

    <div class="mb-4">
        <h2 class="page-title mb-1">Available Events</h2>
        <p class="text-muted small">Discover options, view seats, and secure your place in active university tracks.</p>
    </div>

    <div class="row g-4">
        <% if (locals.events && events.length > 0) { %>
            <% events.forEach(event => { %>
                <div class="col-md-6 col-lg-4">
                    <div class="card event-main-card h-100 p-2">
                        <div class="card-body p-4 d-flex flex-column">
                            
                            <div class="d-flex align-items-start justify-content-between gap-2 mb-3">
                                <h4 class="card-title-text mb-0"><%= event.title %></h4>
                            </div>

                            <p class="text-muted small flex-grow-1 mb-4">
                                <%= event.description %>
                            </p>

                            <div class="meta-container mb-4 pt-3 border-top border-light-subtle">
                                <p>
                                    <span class="meta-label">📅 Date & Time:</span> 
                                    <%= new Date(event.date).toLocaleDateString('en-US', { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' }) %> 
                                    <% if(event.time) { %> at <%= event.time %> <% } %>
                                </p>
                                <p>
                                    <span class="meta-label">📍 Location:</span> 
                                    <%= event.location %>
                                </p>
                                <p>
                                    <span class="meta-label">👥 Total Seats:</span> 
                                    <%= event.capacity %> Available
                                </p>
                                <div class="mt-3">
                                    <span class="category-badge"><%= event.category %></span>
                                </div>
                            </div>

                            <form action="/book-event" method="POST" class="mt-auto">
                                <input type="hidden" name="event_id" value="<%= event.id %>">
                                <button type="submit" class="btn btn-primary w-100 text-center">
                                    Book Event
                                </button>
                            </form>

                        </div>
                    </div>
                </div>
            <% }); %>
        <% } else { %>
            <div class="col-12 text-center py-5">
                <div class="card event-main-card p-5 mx-auto" style="max-width: 500px;">
                    <p class="text-muted mb-0">There are no available events listed at this time.</p>
                </div>
            </div>
        <% } %>
    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>