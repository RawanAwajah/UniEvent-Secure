<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard | UniEvent Secure</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8fafc;
            min-height: 100vh;
            color: #1e293b;
        }

        .navbar-custom {
            background-color: #0f172a; 
            padding: 15px 0;
        }

        .page-title {
            font-weight: 700;
            color: #0f172a;
            letter-spacing: -0.02em;
        }

        .dashboard-card {
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 20px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .dashboard-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 25px rgba(15, 23, 42, 0.08);
            border-color: #cbd5e1;
        }

        .card-title-text {
            font-weight: 700;
            font-size: 1.2rem;
            color: #0f172a;
            letter-spacing: -0.01em;
        }

        .btn-admin-primary {
            background-color: #0a2d6d;
            color: #ffffff;
            border: none;
            font-weight: 600;
            border-radius: 10px;
            padding: 10px 20px;
            transition: all 0.2s ease;
        }
        .btn-admin-primary:hover {
            background-color: #061c47;
            color: #ffffff;
        }

        .btn-admin-success {
            background-color: #10b981;
            color: #ffffff;
            border: none;
            font-weight: 600;
            border-radius: 10px;
            padding: 10px 20px;
            transition: all 0.2s ease;
        }
        .btn-admin-success:hover {
            background-color: #047857;
            color: #ffffff;
        }

        .btn-admin-warning {
            background-color: #f59e0b;
            color: #ffffff;
            border: none;
            font-weight: 600;
            border-radius: 10px;
            padding: 10px 20px;
            transition: all 0.2s ease;
        }
        .btn-admin-warning:hover {
            background-color: #b45309;
            color: #ffffff;
        }

        .btn-admin-info {
            background-color: #0284c7;
            color: #ffffff;
            border: none;
            font-weight: 600;
            border-radius: 10px;
            padding: 10px 20px;
            transition: all 0.2s ease;
        }
        .btn-admin-info:hover {
            background-color: #0369a1;
            color: #ffffff;
        }

        .btn-admin-secondary {
            background-color: #475569;
            color: #ffffff;
            border: none;
            font-weight: 600;
            border-radius: 10px;
            padding: 10px 20px;
            transition: all 0.2s ease;
        }
        .btn-admin-secondary:hover {
            background-color: #334155;
            color: #ffffff;
        }

        .admin-badge {
            font-size: 0.75rem;
            background-color: #dc2626;
            color: #ffffff;
            padding: 4px 10px;
            border-radius: 6px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
    </style>
</head>

<body>

<nav class="navbar navbar-expand-lg navbar-dark navbar-custom shadow-sm">
    <div class="container">
        <a class="navbar-brand fw-bold text-white d-flex align-items-center gap-2" href="/admin">
            UniEvent<span class="text-info">Secure</span>
            <span class="admin-badge">Admin</span>
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarContent">
            <div class="navbar-nav ms-auto gap-2">
                <a class="nav-link active text-white" href="/admin">Admin Home</a>
                <a class="nav-link text-white-50" href="/events/create">Create Event</a>
                <a class="nav-link text-white-50" href="/admin/events">Manage Events</a>
                <a class="nav-link text-white-50" href="/admin/bookings">View Bookings</a>
                <a class="nav-link text-white-50" href="/admin/users">Manage Users</a>
                <a class="nav-link text-warning fw-semibold" href="/logout">Logout</a>
            </div>
        </div>
    </div>
</nav>

<div class="container mt-5 mb-5">

    <div class="mb-5">
        <h1 class="page-title mb-1">Admin Dashboard</h1>
        <p class="text-muted small">Administrative dashboard for managing events, bookings, users, and platform operations.</p>
    </div>

    <div class="row g-4">
        
        <div class="col-md-4">
            <div class="card dashboard-card h-100 p-2">
                <div class="card-body p-4 d-flex flex-column">
                    <div class="mb-3 fs-3">📝</div>
                    <h5 class="card-title-text mb-2">Create Event</h5>
                    <p class="text-muted small flex-grow-1">Create and publish new university events, workshops, seminars, and conferences for students.</p>
                    <a href="/events/create" class="btn btn-admin-primary w-100 mt-3 text-center text-decoration-none">
                        Create Event
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card dashboard-card h-100 p-2">
                <div class="card-body p-4 d-flex flex-column">
                    <div class="mb-3 fs-3">⚙️</div>
                    <h5 class="card-title-text mb-2">Manage Events</h5>
                    <p class="text-muted small flex-grow-1">Manage existing events, update event details, adjust capacities, or remove events when needed.</p>
                    <a href="/admin/events" class="btn btn-admin-success w-100 mt-3 text-center text-decoration-none">
                        Manage Events
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card dashboard-card h-100 p-2">
                <div class="card-body p-4 d-flex flex-column">
                    <div class="mb-3 fs-3">📋</div>
                    <h5 class="card-title-text mb-2">View Bookings</h5>
                    <p class="text-muted small flex-grow-1">View student bookings, registration details, and event participation records across the platform.</p>
                    <a href="/admin/bookings" class="btn btn-admin-warning w-100 mt-3 text-center text-decoration-none">
                        View Bookings
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card dashboard-card h-100 p-2">
                <div class="card-body p-4 d-flex flex-column">
                    <div class="mb-3 fs-3">👥</div>
                    <h5 class="card-title-text mb-2">Manage Users</h5>
                    <p class="text-muted small flex-grow-1">Review registered accounts, alter group privilege ranks, or remove credentials cleanly.</p>
                    <a href="/admin/users" class="btn btn-admin-info w-100 mt-3 text-center text-decoration-none">
                        Manage Users
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card dashboard-card h-100 p-2">
                <div class="card-body p-4 d-flex flex-column">
                    <div class="mb-3 fs-3">📊</div>
                    <h5 class="card-title-text mb-2">Reports</h5>
                    <p class="text-muted small flex-grow-1">Access reports and analytics for users, events, bookings, and overall platform usage.</p>
                    <a href="/admin/reports" class="btn btn-admin-secondary w-100 mt-3 text-center text-decoration-none">
                        View Reports
                    </a>
                </div>
            </div>
        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>